---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Festival Calendar', url: '/festivals/' },
];

const pageTitle = 'Midwest Festival Calendar 2026';
const pageDescription = 'From the Chicago Air & Water Show to the Iowa State Fair to Lollapalooza — time your road trip to the festivals, fairs, and events that define each Midwest destination.';

const festivals = [
  {
    month: 'Jan',
    monthIndex: 0,
    name: 'Milwaukee Winter Beer Fest',
    destination: 'Milwaukee',
    slug: 'milwaukee',
    description: 'Hundreds of craft beers from Wisconsin and beyond, sampled inside the warm confines of the Wisconsin State Fair Park. A perfect excuse to brave the cold and discover new brews.',
  },
  {
    month: 'Jan',
    monthIndex: 0,
    name: 'Cleveland Auto Show',
    destination: 'Cleveland',
    slug: 'cleveland',
    description: 'One of the largest auto shows in the Midwest, showcasing the latest models, concept cars, and automotive innovations at the I-X Center — a must for motor enthusiasts.',
  },
  {
    month: 'Feb',
    monthIndex: 1,
    name: 'Chicago Auto Show',
    destination: 'Chicago',
    slug: 'chicago',
    description: 'The largest auto show in North America takes over McCormick Place with hundreds of vehicles, test tracks, and concept car reveals. A century-old Chicago tradition that draws over half a million visitors.',
  },
  {
    month: 'Feb',
    monthIndex: 1,
    name: 'Cincinnati Bockfest',
    destination: 'Cincinnati',
    slug: 'cincinnati',
    description: 'Cincinnati kicks off spring with its beloved Bockfest — a weekend celebration of bock beer, live music, and a ceremonial parade led by a goat through Over-the-Rhine\'s historic brewery district.',
  },
  {
    month: 'Mar',
    monthIndex: 2,
    name: 'St. Patrick\'s Day (Chicago)',
    destination: 'Chicago',
    slug: 'chicago',
    description: 'Chicago dyes the river green for one of the largest St. Patrick\'s Day celebrations in the country. The downtown parade, dyed river, and pub crawls through the city make this an iconic Midwest event.',
  },
  {
    month: 'Mar',
    monthIndex: 2,
    name: 'NCAA March Madness (Indianapolis)',
    destination: 'Indianapolis',
    slug: 'indianapolis',
    description: 'Indianapolis regularly hosts NCAA Tournament games and Final Four events. The entire city rallies around basketball with fan fests, watch parties, and an electric downtown atmosphere.',
