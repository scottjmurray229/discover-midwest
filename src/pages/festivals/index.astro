  },
  {
    month: 'Apr',
    monthIndex: 3,
    name: 'Detroit Jazz Festival Warm-Up',
    destination: 'Detroit',
    slug: 'detroit',
    description: 'Spring jazz events across Detroit\'s clubs and venues set the stage for the Labor Day main festival. Live performances in intimate settings from Corktown to Midtown warm up the city\'s legendary jazz scene.',
  },
  {
    month: 'May',
    monthIndex: 4,
    name: 'Indianapolis 500',
    destination: 'Indianapolis',
    slug: 'indianapolis',
    description: 'The Greatest Spectacle in Racing draws 300,000+ fans to the Indianapolis Motor Speedway. A month of events leads up to race day — parades, concerts, and the legendary pre-race traditions make this a bucket-list Midwest experience.',
  },
  {
    month: 'May',
    monthIndex: 4,
    name: 'Maifest',
    destination: 'Chicago',
    slug: 'chicago',
    description: 'Lincoln Square celebrates its German heritage with a lively street festival featuring live polka and rock bands, authentic German food, beer gardens, and a maypole dance — a beloved Chicago neighborhood tradition.',
  },
  {
    month: 'Jun',
    monthIndex: 5,
    name: 'Summerfest',
    destination: 'Milwaukee',
    slug: 'milwaukee',
    description: 'Billed as "The World\'s Largest Music Festival," Summerfest stretches across 11 days on Milwaukee\'s lakefront. Over 800 acts on 12 stages, plus incredible food vendors, make this the crown jewel of Midwest festivals.',
