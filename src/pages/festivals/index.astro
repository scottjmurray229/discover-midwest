  },
  {
    month: 'Jun',
    monthIndex: 5,
    name: 'Twin Cities Pride',
    destination: 'Minneapolis',
    slug: 'minneapolis',
    description: 'One of the largest Pride festivals in the Upper Midwest fills Loring Park with live music, art, food vendors, and a massive parade through downtown Minneapolis celebrating LGBTQ+ community and culture.',
  },
  {
    month: 'Jul',
    monthIndex: 6,
    name: 'Taste of Chicago',
    destination: 'Chicago',
    slug: 'chicago',
    description: 'The world\'s largest food festival takes over Grant Park with dozens of Chicago\'s best restaurants serving signature dishes. Live music stages, cooking demos, and lakefront views make this a quintessential summer experience.',
  },
  {
    month: 'Jul',
    monthIndex: 6,
    name: 'Kansas City BBQ Festival',
    destination: 'Kansas City',
    slug: 'kansas-city',
    description: 'The BBQ Capital of the World hosts its annual celebration of smoked meats, with pit masters competing for top honors, live blues and country music, and all-you-can-sample BBQ from KC\'s legendary joints.',
