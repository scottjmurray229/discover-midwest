---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Midwest History & Heritage', url: '/history/' },
];

const pageTitle = 'Midwest History & Heritage — A Timeline of the Heartland';
const pageDescription = 'From the Great Migration to the rise of the automobile industry — trace the history that shaped the American Midwest through the places where that story still stands.';

interface TimelineEvent {
  date: string;
  year: number;
  title: string;
  location: string;
  slug?: string | string[];
  description: string;
  whatToSee?: string;
  side: 'left' | 'right';
  era: 'founding' | 'industrial' | 'modern' | 'legacy';
}

const timeline: TimelineEvent[] = [
  {
    date: '1803',
    year: 1803,
    title: 'The Louisiana Purchase',
    location: 'St. Louis, Missouri',
    slug: 'st-louis',
    description: 'The Louisiana Purchase doubled the size of the United States and opened the Midwest to westward expansion. St. Louis became the "Gateway to the West" -- the launching point for Lewis and Clark\'s expedition and countless settlers heading into the frontier.',
    whatToSee: 'The Gateway Arch stands 630 feet tall on the St. Louis riverfront, commemorating westward expansion. The museum below explores the history of the Louisiana Purchase and the Lewis and Clark expedition.',
    side: 'left',
    era: 'founding',
  },
  {
    date: '1825',
    year: 1825,
    title: 'The Erie Canal Opens',
    location: 'Cleveland, Ohio',
    slug: 'cleveland',
    description: 'The Erie Canal connected the Great Lakes to the Atlantic Ocean, transforming Cleveland and other lakefront cities into major commercial hubs. The canal system sparked a wave of settlement across the Midwest.',
    whatToSee: 'The Cuyahoga Valley National Park preserves remnants of the Ohio & Erie Canal. The Canal Visitor Center tells the story of how waterways built the region.',
    side: 'right',
    era: 'founding',
  },
  {
    date: '1837',
    year: 1837,
    title: 'Chicago Incorporated',
    location: 'Chicago, Illinois',
    slug: 'chicago',
    description: 'Chicago was incorporated as a city with a population of just 4,170. Its location at the junction of the Great Lakes and the Mississippi River watershed made it a natural hub for commerce, and it would grow to become the dominant city of the Midwest.',
    whatToSee: 'The Chicago History Museum chronicles the city\'s explosive growth from frontier outpost to metropolis. The Wrigley Building and Tribune Tower anchor the Magnificent Mile.',
    side: 'left',
    era: 'founding',
  },
  {
    date: '1871',
    year: 1871,
    title: 'The Great Chicago Fire',
    location: 'Chicago, Illinois',
    slug: 'chicago',
    description: 'The Great Chicago Fire burned for three days, destroying 17,000 structures and leaving 100,000 people homeless. But the city rebuilt with astonishing speed, adopting steel-frame construction and becoming the birthplace of the modern skyscraper.',
    whatToSee: 'The Chicago Water Tower is one of few structures to survive the fire. The Chicago Architecture Center offers boat tours showcasing the revolutionary buildings that rose from the ashes.',
    side: 'right',
    era: 'founding',
  },
  {
    date: '1893',
    year: 1893,
    title: 'The World\'s Columbian Exposition',
    location: 'Chicago, Illinois',
    slug: 'chicago',
    description: 'Chicago hosted the World\'s Fair, attracting 27 million visitors and introducing the world to the Ferris wheel, Cracker Jack, and the vision of a "White City." The fair cemented Chicago\'s reputation as a world-class city.',
    whatToSee: 'The Museum of Science and Industry occupies the fair\'s only remaining building. Jackson Park and the Midway Plaisance preserve the fair\'s footprint.',
    side: 'left',
    era: 'founding',
  },
  {
    date: '1903',
    year: 1903,
    title: 'Ford Motor Company Founded',
    location: 'Detroit, Michigan',
    slug: 'detroit',
    description: 'Henry Ford founded the Ford Motor Company in Detroit, beginning the transformation that would make the city the automobile capital of the world. The assembly line revolutionized manufacturing and created the American middle class.',
    whatToSee: 'The Henry Ford Museum and Greenfield Village in Dearborn house an extraordinary collection of American innovation. The Ford Rouge Factory Tour shows a working auto plant.',
    side: 'right',
    era: 'industrial',
  },
  {
    date: '1919',
    year: 1919,
    title: 'The Chicago Race Riots',
    location: 'Chicago, Illinois',
    slug: 'chicago',
    description: 'Racial tensions erupted in a week of violence that killed 38 people and left hundreds homeless. The riots highlighted the tensions of the Great Migration, when millions of Black Americans moved from the South to Midwest cities seeking opportunity.',
    whatToSee: 'The DuSable Museum of African American History documents the Great Migration and its impact on Chicago. Bronzeville\'s historic buildings tell the story of Black Chicago.',
    side: 'left',
    era: 'industrial',
  },
  {
    date: '1927',
    year: 1927,
    title: 'The Gateway to Route 66',
    location: 'St. Louis, Missouri',
    slug: 'st-louis',
    description: 'Route 66 was officially established, running from Chicago to Santa Monica through St. Louis. The "Mother Road" became the most famous highway in America, carrying generations of travelers through the Midwest heartland.',
    whatToSee: 'Historic Route 66 markers dot the landscape from Chicago through Springfield to St. Louis. The Route 66 Association of Missouri preserves the heritage of the original roadway.',
    side: 'right',
    era: 'industrial',
  },
  {
    date: '1930s',
    year: 1930,
    title: 'The Dust Bowl and Great Depression',
    location: 'Des Moines & Omaha',
    slug: ['des-moines', 'omaha'],
    description: 'The Great Depression devastated Midwest farming communities. Drought and dust storms drove thousands from the Plains states. Federal programs like the CCC built parks, bridges, and infrastructure that still serve communities today.',
    whatToSee: 'Iowa\'s Living History Farms near Des Moines trace the evolution of Midwest farming. The Durham Museum in Omaha, housed in a stunning Art Deco Union Station, chronicles the region\'s Depression-era history.',
    side: 'left',
    era: 'industrial',
  },
  {
    date: '1950s',
    year: 1950,
    title: 'The Interstate Highway System',
    location: 'Indianapolis, Indiana',
    slug: 'indianapolis',
    description: 'The Federal Highway Act of 1956 created the Interstate system, and Indianapolis became the "Crossroads of America" where I-65, I-69, I-70, and I-74 converge. The highways transformed Midwest travel and commerce forever.',
    whatToSee: 'The Indianapolis Motor Speedway Museum celebrates Indiana\'s racing heritage. The city\'s downtown canal walk and Monument Circle showcase mid-century urban planning.',
    side: 'right',
    era: 'modern',
  },
  {
    date: '1959',
    year: 1959,
    title: 'The St. Lawrence Seaway Opens',
    location: 'Cleveland & Milwaukee',
    slug: ['cleveland', 'milwaukee'],
    description: 'The opening of the St. Lawrence Seaway connected Great Lakes ports to the Atlantic Ocean, turning Cleveland, Milwaukee, and other lakefront cities into international shipping hubs.',
    whatToSee: 'Cleveland\'s Flats district along the Cuyahoga River has been transformed from industrial docks to a vibrant entertainment district. Milwaukee\'s Third Ward preserves the commercial heritage of the port.',
    side: 'left',
    era: 'modern',
  },
  {
    date: '1965',
    year: 1965,
    title: 'The Gateway Arch Completed',
    location: 'St. Louis, Missouri',
    slug: 'st-louis',
    description: 'Eero Saarinen\'s 630-foot Gateway Arch was completed on the St. Louis riverfront, becoming the tallest monument in the United States and an enduring symbol of westward expansion and Midwest ambition.',
    whatToSee: 'The Gateway Arch National Park includes a tram ride to the top with views of the city and river. The museum below explores the story of westward expansion.',
    side: 'right',
    era: 'modern',
  },
  {
    date: '1995–Present',
    year: 1995,
    title: 'The Rust Belt Renaissance',
    location: 'All Destinations',
    description: 'Cities like Detroit, Cleveland, and Cincinnati are reinventing themselves. Former industrial neighborhoods are becoming food halls, breweries, and arts districts. The Midwest\'s history of building things -- cars, steel, railroads -- is being transformed into a new story of creativity, resilience, and community.',
    side: 'left',
    era: 'legacy',
  },
];

const eraLabels: Record<string, string> = {
  founding: 'Founding & Frontier — 1800s',
  industrial: 'Industrial Age — 1900–1950',
  modern: 'Modern Era — 1950–1990',
  legacy: 'Renaissance & Legacy',
};

const eraGradients: Record<string, string> = {
  founding: 'linear-gradient(135deg, #B71C1C 0%, #D32F2F 100%)',
  industrial: 'linear-gradient(135deg, #4A5568 0%, #2D3748 100%)',
  modern: 'linear-gradient(135deg, #1B5E20 0%, #388E3C 100%)',
  legacy: 'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
};

const eraColors: Record<string, string> = {
  founding: '#D32F2F',
  industrial: '#718096',
  modern: '#388E3C',
  legacy: '#0D7377',
};

// Geo coordinates for map markers
const geoLookup: Record<string, { lat: number; lng: number }> = {
  chicago: { lat: 41.8781, lng: -87.6298 },
  'st-louis': { lat: 38.627, lng: -90.1994 },
  detroit: { lat: 42.3314, lng: -83.0458 },
  cleveland: { lat: 41.4993, lng: -81.6944 },
  milwaukee: { lat: 43.0389, lng: -87.9065 },
  indianapolis: { lat: 39.7684, lng: -86.1581 },
  'des-moines': { lat: 41.5868, lng: -93.625 },
  omaha: { lat: 41.2565, lng: -95.9345 },
  cincinnati: { lat: 39.1031, lng: -84.512 },
  columbus: { lat: 39.9612, lng: -82.9988 },
  'kansas-city': { lat: 39.0997, lng: -94.5786 },
  minneapolis: { lat: 44.9778, lng: -93.265 },
  madison: { lat: 43.0731, lng: -89.4012 },
};

// Build map markers from timeline events that have slugs
const wwiiMapMarkers = timeline
  .filter(e => e.slug)
  .map(e => {
    const slugs = Array.isArray(e.slug) ? e.slug : [e.slug!];
    const primarySlug = slugs[0];
    const geo = geoLookup[primarySlug];
    if (!geo) return null;
    return {
      lat: geo.lat,
      lng: geo.lng,
      title: e.title,
      date: e.date,
      location: e.location,
      era: e.era,
      color: eraColors[e.era],
      url: `/destinations/${primarySlug}/`,
    };
  })
  .filter(Boolean);

// WW2 card videos — 7 clips cycled across 25 events
const ww2CardVideos = Array.from({ length: 7 }, (_, i) => `/videos/pillar/ww2-card-${i + 1}.mp4`);

---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="ww2-hero">
    <video class="ww2-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/history-hero.mp4" type="video/mp4" />
    </video>
    <div class="ww2-hero-gradient"></div>
    <div class="ww2-hero-noise"></div>
    <div class="ww2-hero-content">
      <h1 class="ww2-hero-title">History of the Midwest</h1>
      <p class="ww2-hero-subtitle">From the Louisiana Purchase to the Rust Belt Renaissance -- trace the events that shaped the heartland through the places where that history still stands.</p>
      <div class="ww2-hero-meta">
        <div class="ww2-hero-meta-item">
          <span class="ww2-hero-meta-label">Events</span>
          <span class="ww2-hero-meta-value">12</span>
        </div>
        <div class="ww2-hero-meta-item">
          <span class="ww2-hero-meta-label">Destinations</span>
          <span class="ww2-hero-meta-value">13</span>
        </div>
        <div class="ww2-hero-meta-item">
          <span class="ww2-hero-meta-label">Timeline</span>
          <span class="ww2-hero-meta-value">1803–Present</span>
        </div>
      </div>
    </div>
    <div class="ww2-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="ww2-personal reveal">
    <div class="container-content">
      <blockquote class="ww2-personal-quote">
        <p>I used to think the Midwest was just flat land and highways. Then I started visiting the museums, walking the historic neighborhoods, and reading the stories behind the cities. The Gateway Arch, the Ford assembly lines, the Great Migration, Route 66 -- every Midwest city has layers of history that explain why it is the way it is today. I add heritage stops to every road trip now, and they're often the most memorable part.</p>
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- View Toggle -->
  <div class="container-content" style="padding-top: var(--space-2); padding-bottom: var(--space-4);">
    <div class="ww2-view-toggle">
      <button class="ww2-toggle-btn active" id="ww2BtnTimeline">Timeline</button>
      <button class="ww2-toggle-btn" id="ww2BtnMap">Map</button>
    </div>
  </div>

  <!-- Timeline -->
  <div id="ww2TimelineView">
  <section class="ww2-timeline-section">
    <div class="container-content">
      <h2 class="ww2-timeline-heading reveal">A Story Across the Heartland</h2>
      <p class="ww2-timeline-sub reveal">The Midwest was built by pioneers, immigrants, and industry. From frontier outposts to manufacturing powerhouses to today's cultural renaissance -- these are the places where that history is still visible and still worth understanding.</p>

      <div class="ww2-timeline">
        <div class="ww2-timeline-line" aria-hidden="true"></div>

        {(() => {
          let lastEra = '';
          return timeline.map((event, idx) => {
            const showEra = event.era !== lastEra;
            lastEra = event.era;
            const slugs = Array.isArray(event.slug) ? event.slug : event.slug ? [event.slug] : [];
            const primarySlug = slugs[0];
            const cardVideo = ww2CardVideos[idx % ww2CardVideos.length];
            return (
              <>
                {showEra && (
                  <div class="ww2-era-marker reveal">
                    <div class="ww2-era-pill" style={`background: ${eraGradients[event.era]};`}>
                      {eraLabels[event.era]}
                    </div>
                  </div>
                )}
                <div class={`ww2-event ww2-event--${event.side} reveal`}>
                  <div class="ww2-event-dot" style={`background: ${eraGradients[event.era]};`}></div>
                  {primarySlug && slugs.length === 1 ? (
                    <a href={`/destinations/${primarySlug}/`} class="ww2-event-card">
                      <div class="ww2-event-media" style={`background: ${eraGradients[event.era]};`}>
                        <video class="ww2-event-video" muted loop playsinline preload="none" data-src={cardVideo}></video>
                        <span class="ww2-event-date-badge">{event.date}</span>
                      </div>
                      <div class="ww2-event-body">
                        <h3 class="ww2-event-title">{event.title}</h3>
                        <p class="ww2-event-location">{event.location}</p>
                        <p class="ww2-event-desc">{event.description}</p>
                        {event.whatToSee && (
                          <div class="ww2-event-see">
                            <span class="ww2-event-see-label">What to see today:</span>
                            <p class="ww2-event-see-text">{event.whatToSee}</p>
                          </div>
                        )}
                        <span class="ww2-event-cta">Explore {event.location.split(',')[0]} &rarr;</span>
                      </div>
                      <div class="ww2-event-overlay">
                        <p class="ww2-event-overlay-text">{event.description}</p>
                        {event.whatToSee && (
                          <div class="ww2-event-overlay-see">
                            <span class="ww2-event-overlay-see-label">What to see today:</span>
                            <p>{event.whatToSee}</p>
                          </div>
                        )}
                        <span class="ww2-event-overlay-cta">Explore {event.location.split(',')[0]} &rarr;</span>
                      </div>
                    </a>
                  ) : primarySlug ? (
                    <div class="ww2-event-card ww2-event-card--multi">
                      <div class="ww2-event-media" style={`background: ${eraGradients[event.era]};`}>
                        <video class="ww2-event-video" muted loop playsinline preload="none" data-src={cardVideo}></video>
                        <span class="ww2-event-date-badge">{event.date}</span>
                      </div>
                      <div class="ww2-event-body">
                        <h3 class="ww2-event-title">{event.title}</h3>
                        <p class="ww2-event-location">{event.location}</p>
                        <p class="ww2-event-desc">{event.description}</p>
                        {event.whatToSee && (
                          <div class="ww2-event-see">
                            <span class="ww2-event-see-label">What to see today:</span>
                            <p class="ww2-event-see-text">{event.whatToSee}</p>
                          </div>
                        )}
                        <div class="ww2-event-cta-group">
                          {slugs.map((s) => (
                            <a href={`/destinations/${s}/`} class="ww2-event-cta ww2-event-cta-link">Explore {s.charAt(0).toUpperCase() + s.slice(1)} &rarr;</a>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : (
                    <div class="ww2-event-card ww2-event-card--nolink">
                      <div class="ww2-event-media" style={`background: ${eraGradients[event.era]};`}>
                        <video class="ww2-event-video" muted loop playsinline preload="none" data-src={cardVideo}></video>
                        <span class="ww2-event-date-badge">{event.date}</span>
                      </div>
                      <div class="ww2-event-body">
                        <h3 class="ww2-event-title">{event.title}</h3>
                        <p class="ww2-event-location">{event.location}</p>
                        <p class="ww2-event-desc">{event.description}</p>
                      </div>
                    </div>
                  )}
                </div>
              </>
            );
          });
        })()}
      </div>
    </div>
  </section>

  </div><!-- /ww2TimelineView -->

  <!-- Map View (hidden by default) -->
  <div id="ww2MapView" style="display:none;">
    <section style="padding: var(--space-4) 0 var(--space-8);">
      <div class="container-content">
        <div class="ww2-map-container" id="ww2MapContainer">
          <div class="ww2-map-tooltip" id="ww2MapTooltip">
            <div class="ww2-map-tooltip-title" id="ww2TooltipTitle"></div>
            <div class="ww2-map-tooltip-date" id="ww2TooltipDate"></div>
            <div class="ww2-map-tooltip-location" id="ww2TooltipLocation"></div>
          </div>
          <div id="ww2LeafletMap"></div>
          <div class="ww2-map-legend">
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#D32F2F;"></div>Founding</div>
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#718096;"></div>Industrial</div>
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#388E3C;"></div>Modern</div>
            <div class="ww2-map-legend-item"><div class="ww2-map-legend-dot" style="background:#0D7377;"></div>Legacy</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Bottom CTA -->
  <section class="ww2-cta-section reveal">
    <div class="container-content">
      <div class="ww2-cta-card">
        <h2 class="ww2-cta-heading">Plan a Heritage Trip</h2>
        <p class="ww2-cta-text">Tell our AI planner you want to follow a heritage trail and it will build a chronological itinerary -- the Gateway Arch, Ford Museum, Route 66, and more.</p>
        <a href="/plan/" class="ww2-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What is the most historically significant city in the Midwest?", answer: "Chicago has the strongest claim -- it grew from a frontier town to America's second-largest city in just decades, survived the Great Fire of 1871, hosted the 1893 World's Fair, and became the hub of railroads, meatpacking, and modern architecture. But St. Louis (Gateway to the West), Detroit (the automobile revolution), and Cincinnati (the first major inland city) all have deep historical significance." },
    { question: "What museums cover Midwest history?", answer: "The best include the Henry Ford Museum and Greenfield Village in Dearborn (near Detroit), the Chicago History Museum, the Gateway Arch Museum in St. Louis, the National Underground Railroad Freedom Center in Cincinnati, the DuSable Black History Museum in Chicago, and the Indiana State Museum in Indianapolis. Most charge $10-25 admission." },
    { question: "What is the Great Migration?", answer: "Between 1914 and 1970, approximately six million African Americans moved from the rural South to Northern and Midwestern cities seeking better economic opportunities and escape from Jim Crow laws. Chicago, Detroit, Cleveland, and Milwaukee were major destinations. The migration transformed these cities' culture, music, and demographics." },
    { question: "Can I drive Route 66 through the Midwest?", answer: "Yes -- Route 66 begins at Adams and Michigan in downtown Chicago and runs through Illinois to St. Louis. While the original road is no longer an official highway, much of it is preserved and drivable. You'll find vintage diners, neon signs, and roadside attractions along the way. The Illinois stretch is one of the best-preserved sections of the entire route." },
    { question: "What role did the Midwest play in the Underground Railroad?", answer: "The Midwest was critical to the Underground Railroad. Cincinnati, Indianapolis, and Detroit were major stations on the route to freedom in Canada. Ohio had more Underground Railroad sites than any other state. The National Underground Railroad Freedom Center in Cincinnati is the premier museum dedicated to this history." },
    { question: "Why is Detroit called the Motor City?", answer: "Henry Ford founded the Ford Motor Company in Detroit in 1903 and introduced the moving assembly line in 1913, making cars affordable for ordinary Americans. General Motors, Chrysler, and dozens of other automakers followed. By the 1950s, Detroit produced more cars than any city in the world. The city's identity -- its wealth, its labor history, its boom and decline -- is inseparable from the automobile." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Midwest Heritage Trail Guide"
      description="A chronological PDF guide to the best history museums, landmarks, and heritage sites across the Midwest."
      bullets={[
        'All 13 destinations with top heritage sites',
        'Route 66 road trip planner with stops',
        'Museum guide with hours, prices, and tips',
        'Suggested 5-day heritage trail itinerary',
      ]}
      guideTag="pillar-history"
    />
  </div>

  <!-- Cross-links -->
  <section class="ww2-crosslinks reveal">
    <div class="container-content">
      <h3 class="ww2-crosslinks-heading">Explore More</h3>
      <div class="ww2-crosslinks-grid">
        <a href="/festivals/" class="ww2-crosslink-card">
          <span class="ww2-crosslink-icon">&#127914;</span>
          <span class="ww2-crosslink-label">Festival Calendar</span>
          <span class="ww2-crosslink-desc">Midwest festivals, fairs, and events month by month</span>
        </a>
        <a href="/cuisine/" class="ww2-crosslink-card">
          <span class="ww2-crosslink-icon">&#127860;</span>
          <span class="ww2-crosslink-label">Food & Cuisine</span>
          <span class="ww2-crosslink-desc">23 dishes across 3 regions</span>
        </a>
        <a href="/finer-things/" class="ww2-crosslink-card">
          <span class="ww2-crosslink-icon">&#127866;</span>
          <span class="ww2-crosslink-label">The Finer Things</span>
          <span class="ww2-crosslink-desc">Craft breweries, bourbon bars, and nightlife</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<!-- View Toggle Logic -->
<script>
  const ww2BtnTimeline = document.getElementById('ww2BtnTimeline');
  const ww2BtnMap = document.getElementById('ww2BtnMap');
  const ww2TimelineView = document.getElementById('ww2TimelineView');
  const ww2MapView = document.getElementById('ww2MapView');

  function ww2ShowTimeline() {
    ww2TimelineView!.style.display = '';
    ww2MapView!.style.display = 'none';
    ww2BtnTimeline!.classList.add('active');
    ww2BtnMap!.classList.remove('active');
  }

  function ww2ShowMap() {
    ww2TimelineView!.style.display = 'none';
    ww2MapView!.style.display = '';
    ww2BtnTimeline!.classList.remove('active');
    ww2BtnMap!.classList.add('active');
    if (window.ww2Map) {
      window.ww2Map.invalidateSize();
    }
  }

  ww2BtnTimeline?.addEventListener('click', ww2ShowTimeline);
  ww2BtnMap?.addEventListener('click', ww2ShowMap);
</script>

<!-- Lazy-load & autoplay WW2 card videos on scroll -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ww2VideoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            if (!video.src && video.dataset.src) {
              video.src = video.dataset.src;
            }
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      { rootMargin: '100px' }
    );
    document.querySelectorAll('.ww2-event-video').forEach((v) => ww2VideoObserver.observe(v));
  }
</script>

<!-- Leaflet Map for WWII -->
<script is:inline define:vars={{ markers: wwiiMapMarkers }}>
  // Load Leaflet CSS
  if (!document.getElementById('leaflet-css')) {
    var lnk = document.createElement('link');
    lnk.id = 'leaflet-css';
    lnk.rel = 'stylesheet';
    lnk.href = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css';
    document.head.appendChild(lnk);
  }

  function initWwiiMap() {
    var mapEl = document.getElementById('ww2LeafletMap');
    if (!mapEl || typeof L === 'undefined') return;

    var map = L.map(mapEl, {
      center: [41.0, -89.0],
      zoom: 5,
      scrollWheelZoom: false,
      minZoom: 4,
      maxZoom: 12,
      maxBounds: [[35, -105], [50, -80]],
      zoomControl: false,
      attributionControl: false,
    });

    window.ww2Map = map;

    L.control.attribution({ prefix: false }).addTo(map);
    L.control.zoom({ position: 'topright' }).addTo(map);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '\u00a9 <a href="https://www.openstreetmap.org/copyright">OSM</a> \u00a9 <a href="https://carto.com/">CARTO</a>',
      maxZoom: 19,
    }).addTo(map);

    function makeCircle(color, size, stroke) {
      return L.divIcon({
        className: '',
        html: '<div style="width:' + size + 'px;height:' + size + 'px;border-radius:50%;background:' + color + ';border:2px solid ' + stroke + ';box-shadow:0 0 6px rgba(0,0,0,0.3);cursor:pointer;"></div>',
        iconSize: [size, size],
        iconAnchor: [size / 2, size / 2],
      });
    }

    var tooltip = document.getElementById('ww2MapTooltip');
    var tooltipTitle = document.getElementById('ww2TooltipTitle');
    var tooltipDate = document.getElementById('ww2TooltipDate');
    var tooltipLocation = document.getElementById('ww2TooltipLocation');
    var container = document.getElementById('ww2MapContainer');

    markers.forEach(function(m) {
      var icon = makeCircle(m.color, 16, '#ffffff');
      var marker = L.marker([m.lat, m.lng], { icon: icon, title: m.title }).addTo(map);

      marker.on('mouseover', function(e) {
        if (tooltipTitle) tooltipTitle.textContent = m.title;
        if (tooltipDate) tooltipDate.textContent = m.date;
        if (tooltipLocation) tooltipLocation.textContent = m.location;
        if (tooltip) tooltip.classList.add('ww2-tooltip-visible');
        if (container && tooltip) {
          var pt = e.containerPoint;
          tooltip.style.left = (pt.x + 12) + 'px';
          tooltip.style.top = (pt.y - 10) + 'px';
        }
      });

      marker.on('mouseout', function() {
        if (tooltip) tooltip.classList.remove('ww2-tooltip-visible');
      });

      marker.on('click', function() {
        window.location.href = m.url;
      });
    });
  }

  // Load Leaflet JS
  if (typeof L !== 'undefined') {
    initWwiiMap();
  } else {
    var lscript = document.createElement('script');
    lscript.src = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js';
    lscript.onload = initWwiiMap;
    document.head.appendChild(lscript);
  }
</script>

